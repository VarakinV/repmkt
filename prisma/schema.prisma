// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(ADMIN)
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

// ─── Agent Finder ───────────────────────────────────────────────────────────

enum JobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum SearchMode {
  MARKET
  CUSTOM_URL
}

enum ListingProvider {
  REALTOR_CA
  REALTOR_COM
  ZILLOW
}

enum EmailVerificationStatus {
  UNKNOWN
  VERIFIED
  RISKY
  INVALID
}

model Market {
  id          String           @id @default(cuid())
  countryCode String
  regionCode  String
  city        String
  label       String
  provider    ListingProvider
  startUrl    String           @db.Text
  isActive    Boolean          @default(true)
  metadata    Json?
  jobs        AgentFinderJob[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([countryCode, regionCode, city, provider])
  @@index([countryCode, regionCode, city])
}

model AgentFinderJob {
  id             String           @id @default(cuid())
  status         JobStatus        @default(QUEUED)
  mode           SearchMode
  provider       ListingProvider
  marketId       String?
  market         Market?          @relation(fields: [marketId], references: [id], onDelete: SetNull)
  countryCode    String
  regionCode     String
  city           String
  customStartUrl String?          @db.Text
  maxListings    Int              @default(10)
  requestPayload Json?
  resultSummary  Json?
  errorMessage   String?          @db.Text
  startedAt      DateTime?
  completedAt    DateTime?
  leads          AgentLead[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([status, createdAt])
}

model AgentLead {
  id                      String                  @id @default(cuid())
  jobId                   String
  job                     AgentFinderJob          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  provider                ListingProvider
  providerListingId       String?
  listingUrl              String?                 @db.Text
  listingAddress          String?
  listingPrice            String?
  rawListing              Json?
  agentName               String
  normalizedAgentName     String
  brokerageName           String?
  normalizedBrokerageName String?
  phone                   String?
  phoneSource             String?
  agentWebsite            String?                 @db.Text
  brokerageWebsite        String?                 @db.Text
  email                   String?
  emailSource             String?
  emailVerified           Boolean                 @default(false)
  emailVerificationStatus EmailVerificationStatus @default(UNKNOWN)
  confidenceScore         Float                   @default(0)
  rank                    Int?
  sourceSummary           Json?
  enrichmentLog           Json?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  @@index([jobId, rank])
  @@index([normalizedAgentName, normalizedBrokerageName])
}
